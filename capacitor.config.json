{
  "appId": "com.aiaccounting.app",
  "appName": "AI记账",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#667eea",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#667eea"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#667eea",
    "allowsLinkPreview": false,
    "scrollEnabled": false
  },
  "android": {
    "backgroundColor": "#667eea",
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": false
  }
}
